# Frontend (públicas, embutidas pelo Vite)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Kaline Offline (local-first) — opcionais; default seguro mantém o app em modo online.
# VITE_KALINE_RUNTIME_MODE: "online" (default) | "offline"
VITE_KALINE_RUNTIME_MODE=online
# URL da API local da Kaline Offline (loopback). Default: http://127.0.0.1:64113
VITE_KALINE_LOCAL_API=http://127.0.0.1:64113

# Supabase server-side
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OpenRouter server-side
OPENROUTER_API_KEY=
OPENROUTER_CHAT_MODEL=
OPENROUTER_FAST_MODEL=
OPENROUTER_REASONING_MODEL=
OPENROUTER_TRANSCRIBE_MODEL=
OPENROUTER_IMAGE_MODEL=
OPENROUTER_TTS_MODEL=
OPENROUTER_TTS_VOICE=
OPENROUTER_MODEL_PRIMARY=
OPENROUTER_TEXT_MODEL_PRIMARY=
OPENROUTER_STT_PRIMARY_MODEL=
OPENROUTER_VISION_MODEL_PRIMARY=
OPENROUTER_TTS_PRIMARY_MODEL=
OPENROUTER_APP_NAME=
OPENROUTER_SITE_URL=

# URL pública do app, usada em headers de providers externos
APP_PUBLIC_URL=

# Providers opcionais
GROQ_API_KEY=

# Olhar de Kairós — chave simétrica usada para cifrar o snapshot servido em
# GET /api/bridge/olhar-de-kairos. Precisa ser idêntica à KALINE_BRIDGE_SHARED_KEY
# configurada em local-server/.env de cada device que for puxar o snapshot.
KALINE_BRIDGE_SHARED_KEY=

# "Buscar do Offline" (lido pelo app ONLINE, não pelo offline): URL da Kaline Offline
# na máquina do usuário. A chamada é client-side (o Worker da nuvem não acessa 127.0.0.1).
VITE_KALINE_OFFLINE_LOCAL_URL=http://127.0.0.1:64113
