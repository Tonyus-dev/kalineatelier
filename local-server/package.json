{
  "name": "kaline-local-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Servidor local-first da Kaline Offline. Isolado da raiz (bun). Escuta apenas em 127.0.0.1:4517.",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && node -e \"require('node:fs').copyFileSync('src/db/schema.sql', 'dist/db/schema.sql')\"",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "fastify": "^5.2.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.7",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
