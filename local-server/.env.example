KALINE_LOCAL_HOST=127.0.0.1
KALINE_LOCAL_PORT=64113
KALINE_DATA_DIR=./data
KALINE_DATABASE_PATH=./data/kaline.sqlite

# Model provider
KALINE_MODEL_PROVIDER=ollama
KALINE_MODEL_FALLBACK_TO_MOCK=false

# Modelos leves recomendados para a Kaline Offline (máquinas modestas)
KALINE_MODEL_PRIMARY=qwen2.5:1.5b
KALINE_MODEL_FALLBACK=llama3.2:1b

KALINE_MODEL_GENERAL=qwen2.5:1.5b
KALINE_MODEL_CODER=qwen2.5-coder:1.5b
KALINE_MODEL_SUMMARY=qwen2.5:1.5b

KALINE_MODEL_TIMEOUT_MS=180000
KALINE_MODEL_MAX_INPUT_CHARS=24000

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL_GENERAL=
OPENROUTER_MODEL_CODER=
OPENROUTER_MODEL_SUMMARY=

# ==============================
# Kaline Local — Ollama
# ==============================

OLLAMA_ENABLED=true
OLLAMA_BASE_URL=http://127.0.0.1:11434

OLLAMA_MODEL_GENERAL=qwen2.5:1.5b
OLLAMA_MODEL_ROUTER=llama3.2:1b
OLLAMA_MODEL_SUMMARY=llama3.2:1b
OLLAMA_MODEL_REASONING=llama3.2:1b

OLLAMA_MODEL_TEXT_FALLBACK=llama3.2:1b

OLLAMA_MODEL_VISION=qwen3.5:2b
OLLAMA_MODEL_VISION_FALLBACK=qwen3.5:0.8b

# Coder não faz parte da pilha oficial local da Kaline (trabalho de código pesado
# continua fora, em ferramentas como VS Code/Codex/Claude/Cline).
OLLAMA_MODEL_CODER=qwen3.5:0.8b

OLLAMA_REQUEST_TIMEOUT_MS=120000

# Domínios críticos exigem fonte/ferramenta confiável
CRITICAL_DOMAIN_REQUIRES_SOURCE=true

# Visão local é experimental; não usar como conclusão final em documentos sensíveis
VISION_ENABLED=true
VISION_EXPERIMENTAL=true

# ==============================
# Kaline Local — Whisper
# ==============================

KALINE_TRANSCRIBE_PROVIDER=whisper_cpp
WHISPER_ENABLED=true
WHISPER_ENGINE=whisper.cpp
WHISPER_MODEL=small
WHISPER_CPP_BIN=/caminho/para/whisper.cpp/build/bin/whisper-cli
WHISPER_MODEL_PATH=/caminho/para/whisper.cpp/models/ggml-small.bin
WHISPER_LANGUAGE=pt
WHISPER_REQUEST_TIMEOUT_MS=180000

# ==============================
# Kaline Local — TTS (kokoro-python)
# ==============================

TTS_PROVIDER=kokoro-python

# Provider Python (Dora PT-BR offline)
KOKORO_PYTHON_ENABLED=true
KOKORO_PYTHON_BIN=/home/tonyus/Kaline/motores/kokoro-python-venv/bin/python
KOKORO_PYTHON_BASE_DIR=/home/tonyus/Kaline/motores/kokoro-python
KOKORO_PYTHON_TIMEOUT_MS=120000

KOKORO_DORA_MODEL_SHA256=496dba118d1a58f5f3db2efc88dbdc216e0483fc89fe6e47ee1f2c53f18ad1e4

# Fallback experimental kokoro-js (af_bella). Não usar pf_dora aqui.
KOKORO_ENABLED=false
KOKORO_ENGINE=onnx
KOKORO_MODEL=kokoro-82m
KOKORO_MODEL_PATH=
KOKORO_VOICES_PATH=
KOKORO_DEFAULT_VOICE=af_bella
KOKORO_DEFAULT_LANG=pt-br
KOKORO_DEFAULT_SPEED=1.0

KALINE_TUNNEL_MODE=disabled
KALINE_DEVICE_ID=
KALINE_CLOUD_BRIDGE_URL=
KALINE_BRIDGE_PUBLIC_KEY=
# Olhar de Kairós — pull único de snapshot cifrado da Totalidade (mode=pull_only).
# KALINE_BRIDGE_SHARED_KEY precisa ser idêntica à configurada no deployment da Totalidade.
# Se deixada em branco, a Kaline Local GERA e PERSISTE uma chave automaticamente no
# primeiro start (em ./data/bridge-shared-key.txt) e mostra o valor no console — copie
# esse valor para o lado online. Só preencha manualmente se quiser repetir a chave de
# uma instalação anterior (reinstalação, restauração de backup, parear outro device
# com a mesma chave).
# KALINE_BRIDGE_USER_TOKEN é um token de sessão (bearer) da sua conta na Totalidade.
KALINE_BRIDGE_SHARED_KEY=
KALINE_BRIDGE_USER_TOKEN=

# CORS — origens permitidas (separadas por vírgula). Inclui o frontend local (Vite) e,
# se for usar "Buscar do Offline" no app online, o domínio dele (ex.: a Totalidade).
# O @fastify/cors já responde o preflight OPTIONS para as origens listadas.
KALINE_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
