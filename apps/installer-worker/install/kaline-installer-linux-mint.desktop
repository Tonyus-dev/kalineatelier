[Desktop Entry]
Type=Application
Name=Instalar Kaline Offline (Linux Mint)
Comment=Bootstrap público: localiza/clona o repositório e chama o instalador real da Kaline Offline
Exec=bash -lc 'cd "$(dirname "%k" | sed "s|^file://||")" && bash kaline-installer-linux-mint.sh; echo; read -p "Pressione Enter para fechar..."'
Terminal=true
Categories=Utility;
